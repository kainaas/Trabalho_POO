@startuml JavaEventPlanner
title Java Event Planner - Diagrama de Classes

skinparam classAttributeIconSize 0
skinparam linetype ortho
left to right direction

package Model {

    abstract class AbstractModel {
        # propertyChangeSupport : PropertyChangeSupport
        + addPropertyChangeListener(l)
        + removePropertyChangeListener(l)
        # firePropertyChange(name, old, new)
    }

    class CalendarModel {
        - currentViewDate : LocalDate
        - darkMode : boolean
        - eventSelected : Event
        - currentMode : ViewMode
        - eventList : List<Event>
        + addEvent(e) : boolean
        + removeEvent(e)
        + addEventForced(e)
        + removeOccurrence(master, day)
        + getEventsOn(day) : List<Event>
        + hasEventsOn(day) : boolean
        + searchEvents(keyword) : List<Event>
        + getAllEvents() : List<Event>
        + loadEvents(events)
    }

    class Event {
        - date : LocalDate
        - time : LocalTime
        - duration : long
        - title : String
        - location : String
        - description : String
        - category : String
        - reminderLeadMinutes : long
        - recurrence : Recurrence
        - attendees : List<Attendee>
        - exceptionDates : Set<LocalDate>
        + occursOn(day) : boolean
        + occurrenceStart(day) : LocalDateTime
        + isRecurring() : boolean
        + addAttendee(a)
        + addExceptionDate(d)
    }

    class Attendee {
        - name : String
        - email : String
    }

    enum Recurrence {
        NONE
        DAILY
        WEEKLY
        MONTHLY
    }

    class EventStorage {
        - file : File
        + save(events)
        + load() : List<Event>
    }

    class EventValidationException
    class StorageException
}

package Controller {
    class Controller {
        - model : CalendarModel
        - storage : EventStorage
        + buildEvent(...) : Event
        + createEvent(e) : boolean
        + replaceEvent(old, new) : boolean
        + editOccurrence(master, day, edited)
        + deleteEvent(e)
        + deleteOccurrence(master, day)
        + search(keyword) : List<Event>
        + goPrevious() / goNext()
        + setViewMode(m) / setDarkMode(b)
    }
}

package View {
    enum ViewMode {
        DAY
        WEEK
        MONTH
        YEAR
    }

    class modeColors {
        + {static} LIGHT : modeColors
        + {static} DARK : modeColors
        + {static} of(darkMode) : modeColors
    }

    class CalendarView {
        + propertyChange(evt)
        - refreshAll()
        - doSearch()
    }

    class TopPanel {
        + bind(controller)
        + refresh()
    }

    class CalendarMonthPanel {
        + refresh()
    }

    class DayEventsPanel {
        + openCreate()
        + openEdit()
        + refresh()
    }

    class EventFormDialog {
        - result : Event
        + getResult() : Event
    }

    class ReminderService {
        - jaAvisados : Set<String>
        + start()
        + run()
    }

    class Icons
    enum IconFiles
}

class Main {
    + {static} main(args)
}

' Heranca
AbstractModel <|-- CalendarModel
Exception <|-- EventValidationException
Exception <|-- StorageException
JFrame <|-- CalendarView
JPanel <|-- TopPanel
JPanel <|-- CalendarMonthPanel
JPanel <|-- DayEventsPanel
JDialog <|-- EventFormDialog
Runnable <|.. ReminderService
PropertyChangeListener <|.. CalendarView

' Composicao / associacao
CalendarModel "1" *-- "*" Event
Event "1" *-- "*" Attendee
Event "1" --> "1" Recurrence
CalendarModel --> ViewMode
Controller --> CalendarModel
Controller --> EventStorage
EventStorage ..> Event
ReminderService --> CalendarModel

CalendarView *-- TopPanel
CalendarView *-- CalendarMonthPanel
CalendarView *-- DayEventsPanel
CalendarView --> Controller
TopPanel --> Controller
CalendarMonthPanel --> Controller
DayEventsPanel --> Controller
DayEventsPanel ..> EventFormDialog
EventFormDialog --> Controller
TopPanel ..> modeColors
CalendarMonthPanel ..> modeColors
DayEventsPanel ..> modeColors

Main ..> CalendarModel
Main ..> Controller
Main ..> CalendarView
Main ..> ReminderService

CalendarModel ..> AbstractModel
@enduml
